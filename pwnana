#!/usr/bin/env python3
"""Pronounceable, keyboard-alternating password generator."""
import random
import argparse
import json
import shutil
from pathlib import Path

# QWERTY layout — 変えたければここを編集
LAYOUT = {
    'left_consonants':  list('wrtsfgzxcvbq'),
    'left_vowels':      list('ea'),
    'right_consonants': list('yphjklnm'),
    'right_vowels':     list('uio'),
}

# 日本語話者が読みやすい母音中心ダイグラフ
DIGRAPHS = ['oo', 'ee', 'ii', 'ou', 'ai', 'au']

# Leet 置換マップ — カスタマイズ可能
# 値が数字 → -d で使用、記号 → -s で使用
LEET = {
    'i': '!',
    'a': '@',
    's': '$',
    'e': '3',
    'o': '0',
    't': '7',
    'q': '9',
    'b': '6',
    'g': '8',
}

GOROAWASE_PATH = Path(__file__).resolve().with_name('goroawase.json')


def _load_goroawase(path):
    with path.open(encoding='utf-8') as f:
        data = json.load(f)
    return [(label, digits) for label, digits in data]


GOROAWASE = _load_goroawase(GOROAWASE_PATH)
GOROAWASE_4 = [(label, digits) for label, digits in GOROAWASE if len(digits) == 4]

DEFAULT_LENGTH = 16
MIN_LENGTH = 8
BANNED_UPPERCASE = {'O', 'I'}


def _leet(result, want_digit):
    """LEET マップを使って1文字置換する。該当なしなら False を返す。"""
    pred = str.isdigit if want_digit else lambda c: not c.isdigit()
    candidates = [i for i, c in enumerate(result)
                  if c in LEET and pred(LEET[c])]
    if not candidates:
        return False
    idx = random.choice(candidates)
    result[idx] = LEET[result[idx]]
    return True


def _apply_default_rules(result):
    """デフォルト可読性ルールを適用する。"""
    for i, c in enumerate(result):
        if c in BANNED_UPPERCASE:
            result[i] = c.lower()


def _is_consonant(c):
    return c.isalpha() and c.lower() not in {'a', 'e', 'i', 'o', 'u'}


def _fixed_positions(length):
    positions = [i for i in range(3, length - 1, 4) if 1 <= i <= length - 2]
    return positions or [max(1, length // 2)]


def _fixed_goro_start_positions(length):
    positions = [i for i in range(0, length - 3, 4)]
    return positions or [0]


def _even_count(count):
    count = max(2, count)
    if count % 2 != 0:
        count += 1
    return count


def _default_count():
    terminal = shutil.get_terminal_size(fallback=(80, 24))
    return _even_count(terminal.lines // 2)


def _unit(from_hand):
    """2文字の発音可能チャンクを生成し、(chars, next_hand) を返す。"""
    lc = LAYOUT['left_consonants']
    lv = LAYOUT['left_vowels']
    rc = LAYOUT['right_consonants']
    rv = LAYOUT['right_vowels']

    if from_hand == 'left':
        if random.getrandbits(1):
            return random.choice(rv) + random.choice(lc), 'left'
        else:
            return random.choice(rc) + random.choice(lv), 'left'
    else:
        if random.getrandbits(1):
            return random.choice(lv) + random.choice(rc), 'right'
        else:
            return random.choice(lc) + random.choice(rv), 'right'


def generate(length, digit=False, symbol=False, goroawase=False):
    """(password, hint) を返す。hint は語呂合わせ時のみ文字列、それ以外は None。"""
    chunks = []
    hand = random.choice(['left', 'right'])

    while sum(len(c) for c in chunks) < length:
        if random.random() < 0.2:
            chunks.append(random.choice(DIGRAPHS))
        else:
            unit, hand = _unit(hand)
            chunks.append(unit)

    result = list(''.join(chunks)[:length])
    hint = None

    used_positions = set()
    fixed_positions = _fixed_positions(length)

    if goroawase and GOROAWASE_4:
        label, digits = random.choice(GOROAWASE_4)
        pos = random.choice(_fixed_goro_start_positions(length))
        for i, d in enumerate(digits):
            if pos + i < length:
                result[pos + i] = d
                used_positions.add(pos + i)
        hint = label
    elif digit and not _leet(result, want_digit=True):
        candidates = [p for p in fixed_positions if p not in used_positions]
        pos = random.choice(candidates or fixed_positions)
        result[pos] = str(random.randint(0, 9))
        used_positions.add(pos)

    if symbol and not _leet(result, want_digit=False):
        symbols = [v for v in LEET.values() if not v.isdigit()]
        candidates = [p for p in fixed_positions if p not in used_positions]
        pos = random.choice(candidates or fixed_positions)
        result[pos] = random.choice(symbols)

    if _is_consonant(result[-1]) and result[-1].lower() != 'n':
        vowels = LAYOUT['left_vowels'] + LAYOUT['right_vowels']
        result[-1] = random.choice(vowels)

    _apply_default_rules(result)
    return ''.join(result), hint


def main():
    p = argparse.ArgumentParser(
        prog='pwnana',
        description='Pronounceable, keyboard-alternating password generator',
    )
    p.add_argument('length', nargs='?', type=int, default=DEFAULT_LENGTH,
                   help=f'Password length (min {MIN_LENGTH}, default {DEFAULT_LENGTH})')
    p.add_argument('count',  nargs='?', type=int,
                   help='Number of passwords to generate (default: about half the terminal height)')
    p.add_argument('-d', '--digit',     action='store_true', help='Include one digit')
    p.add_argument('-s', '--symbol',    action='store_true', help='Include one symbol')
    p.add_argument('-g', '--goroawase', action='store_true', help='Embed goroawase digits with hint')
    args = p.parse_args()

    length = max(MIN_LENGTH, args.length)
    count = _default_count() if args.count is None else _even_count(args.count)

    for _ in range(count):
        pw, hint = generate(length, args.digit, args.symbol, args.goroawase)
        if hint:
            print(f"{pw}  [{hint}]")
        else:
            print(pw)


if __name__ == '__main__':
    main()
